# Auricrux OSS Backend .gitignore

# Build outputs
bin/
obj/
dist/
build/
*.o
*.so
__pycache__/
*.py[cod]
*$py.class

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.user
*.suo

# Environment
.env
.env.local
.env.*.local
local.settings.json

# Dependencies
node_modules/
packages/
venv/
env/
.venv

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TTS Models (large files)
tts-service/.cache/
tts-service/*.wav
root/.local/share/tts_models/

# Docker
docker-compose.override.yml
.dockerignore

# Temp files
temp/
tmp/
*.tmp
.temp/

# OS files
Thumbs.db
.DS_Store
